# Copy this file to .env and fill in real values. Never commit the real .env file.

PORT=5000

# Local MongoDB or a MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/digital_scrapbook

# Long random string used to sign JWTs. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# How long a login session stays valid
JWT_EXPIRES_IN=7d

# Frontend origin allowed to call this API with credentials
CLIENT_ORIGIN=http://localhost:5173
